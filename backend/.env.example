# General
NODE_ENV=production
PORT=5000
FRONTEND_URL=http://localhost:3000,https://your-nextjs-app.vercel.app

# Database Details 
# Render handles these automatically by injecting: DATABASE_URL, DB_USER, DB_PASSWORD, etc.
# DB_USER=
# DB_HOST=
# DB_NAME=
# DB_PASSWORD=
# DB_PORT=5432

# Authentication
JWT_SECRET=super_secret_minimum_32_characters_for_security_12345
JWT_EXPIRES_IN=7d

